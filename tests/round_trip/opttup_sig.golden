sig/v1
scope OptTup.Calc
in items inp array(option(int))
in maybe_amount inp option(money)
in mixed inp option(tuple(@OptTup.Pair,@OptTup.Choice))
in pair inp tuple(int,money)
out combo tuple(@OptTup.Choice,option(@OptTup.Pair))
out result option(rat)
def enum OptTup.Choice
  ctor No -
  ctor Yes rat
def struct OptTup.Pair
  field first int
  field second money

